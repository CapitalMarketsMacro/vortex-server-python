# ============================================================================
# VortexServerPython — Environment Variables Reference
# ============================================================================
# All settings use the VORTEX_ prefix. Nested objects use __ as delimiter.
# Copy this file to .env for local dev, or use as a ConfigMap/Secret template
# for OpenShift / Kubernetes.
#
# pydantic-settings reads these automatically. Every field has a safe default
# (localhost) so the server CAN start without any env vars, but in production
# you MUST set the values marked [REQUIRED].
# ============================================================================

# ── Server ──────────────────────────────────────────────────────────────────
VORTEX_PORT=8080
VORTEX_HOST=0.0.0.0

# ── Observability ───────────────────────────────────────────────────────────
VORTEX_LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
VORTEX_LOG_FORMAT=auto                      # auto | json | console
                                            #   auto = console for DEBUG, json otherwise
VORTEX_SHUTDOWN_TIMEOUT=30.0                # seconds — bounded graceful shutdown

# ── MongoDB [REQUIRED in production] ────────────────────────────────────────
# Stores transport and table configuration. The server reads on startup;
# the admin GUI reads and writes.
VORTEX_MONGO__URI=mongodb://localhost:27017/
VORTEX_MONGO__DATABASE=Vortex

# ── Admin GUI ───────────────────────────────────────────────────────────────
VORTEX_ADMIN__HOST=0.0.0.0
VORTEX_ADMIN__PORT=8090
VORTEX_ADMIN__SECRET_KEY=change-me-in-production    # Flask session signing key
VORTEX_ADMIN__VORTEX_URL=http://localhost:8080      # base URL of the data server
                                                    # the admin proxies /api/status from here
VORTEX_ADMIN__VORTEX_STATUS_TIMEOUT=2.0             # seconds — timeout for status proxy

# ============================================================================
# OpenShift / Kubernetes deployment notes:
#
# ConfigMap (non-secret):
#   VORTEX_PORT, VORTEX_HOST, VORTEX_LOG_LEVEL, VORTEX_LOG_FORMAT,
#   VORTEX_SHUTDOWN_TIMEOUT, VORTEX_MONGO__DATABASE,
#   VORTEX_ADMIN__HOST, VORTEX_ADMIN__PORT, VORTEX_ADMIN__VORTEX_URL,
#   VORTEX_ADMIN__VORTEX_STATUS_TIMEOUT
#
# Secret (sensitive — base64-encoded):
#   VORTEX_MONGO__URI              (may contain credentials)
#   VORTEX_ADMIN__SECRET_KEY       (Flask session signing key)
#
# Inject via envFrom in the Deployment spec:
#   envFrom:
#     - configMapRef:
#         name: vortex-config
#     - secretRef:
#         name: vortex-secrets
# ============================================================================
